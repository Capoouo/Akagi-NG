{
  "name": "akagi-ng-desktop",
  "private": true,
  "version": "1.0.7",
  "description": "Akagi-NG Electron Desktop App",
  "author": "Akagi-NG Contributors",
  "license": "AGPL-3.0",
  "main": "../dist/main/main.js",
  "scripts": {
    "dev": "wait-on http://localhost:5173 && tsc -p tsconfig.json && electron .",
    "dev:mock": "wait-on http://localhost:5173 && tsc -p tsconfig.json && electron . --mock",
    "build": "tsc -p tsconfig.json",
    "package": "electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "me.akagi.ng",
    "publish": [
      {
        "provider": "github",
        "owner": "Xe-Persistent",
        "repo": "Akagi-NG"
      }
    ],
    "artifactName": "Akagi-NG-${version}-${os}-${arch}.${ext}",
    "productName": "Akagi-NG",
    "icon": "../assets/torii.ico",
    "electronLanguages": [
      "en-US",
      "zh-CN",
      "zh-TW",
      "ja"
    ],
    "directories": {
      "output": "../dist/release",
      "buildResources": "build"
    },
    "files": [
      {
        "from": "../dist/main",
        "to": "dist/main"
      },
      {
        "from": "../dist/renderer",
        "to": "dist/renderer"
      },
      "package.json",
      "!**/*.map"
    ],
    "extraMetadata": {
      "main": "dist/main/main.js"
    },
    "extraFiles": [
      {
        "from": "../assets",
        "to": "assets"
      },
      {
        "from": "../build/extra",
        "to": "."
      },
      {
        "from": "../dist/backend/akagi-ng",
        "to": "bin"
      }
    ],
    "npmRebuild": false,
    "win": {
      "target": "zip",
      "icon": "../assets/torii.ico",
      "extraFiles": [
        {
          "from": "../README.txt",
          "to": "."
        },
        {
          "from": "../LICENSE",
          "to": "."
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "../assets/torii.icns",
      "category": "public.app-category.games",
      "binaries": [
        "Contents/bin/python/bin/akagi-ng"
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "../assets/torii.png",
      "extraFiles": [
        {
          "from": "../README.txt",
          "to": "."
        },
        {
          "from": "../LICENSE",
          "to": "."
        }
      ]
    },
    "copyright": "Copyright (C) 2026 Akagi-NG Contributors"
  }
}
